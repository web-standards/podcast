{
	"name": "podcast",
	"private": true,
	"type": "module",
	"files": [
		"src/episodes/"
	],
	"scripts": {
		"test": "npx editorconfig-checker && npx eslint",
		"build": "rm -rf dist && eleventy",
		"deploy:rsync": "rsync --archive --verbose --compress --delete --delete-excluded --exclude '.DS_Store' --copy-links",
		"deploy:cover": "npm run deploy:rsync -- ./src/cover.png deploy@web-standards.ru:/opt/sites/web-standards.ru/public/podcast/",
		"deploy:mp3": "npm run deploy:rsync -- ./src/mp3/ deploy@web-standards.ru:/opt/sites/web-standards.ru/public/podcast/episodes/",
		"deploy:feed": "npm run deploy:rsync -- ./dist/index.xml deploy@web-standards.ru:/opt/sites/web-standards.ru/public/podcast/feed/",
		"deploy": "npm run deploy:cover && npm run deploy:mp3 && npm run deploy:feed",
		"new": "node scripts/new.js",
		"file-size": "node scripts/feed/file-size.js",
		"prepare": "husky || true",
		"wav": "node scripts/wav.js",
		"mp3": "node scripts/mp3.js",
		"hosts": "node scripts/hosts.js"
	},
	"engines": {
		"node": ">=24"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.5",
		"@eslint/js": "^10.0.1",
		"@eslint/markdown": "^8.0.1",
		"editorconfig-checker": "^6.1.1",
		"eslint": "^10.2.1",
		"get-mp3-duration": "^1.0.0",
		"globals": "^17.5.0",
		"html-minifier-terser": "^7.2.0",
		"husky": "^9.1.7",
		"js-yaml": "^4.1.1",
		"minify-xml": "^4.5.2",
		"node-id3": "^0.2.9"
	}
}
